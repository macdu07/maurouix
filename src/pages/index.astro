    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Portfolio de Mauricio Correa (MauroUIX) — Diseñador Web & Desarrollador UI/UX en Colombia. +10 años creando experiencias digitales para empresas." />
    <title>MauroUIX — Diseñador Web & Desarrollador UI/UX</title>
