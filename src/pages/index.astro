            "https://www.facebook.com/MauricioCorreaD"
          ]
        },
        {
          "@type": "ProfessionalService",
          "@id": "https://maurouix.com/#service",
          "name": "MauroUIX",
          "url": "https://maurouix.com",
          "provider": { "@id": "https://maurouix.com/#person" },
          "areaServed": { "@type": "Country", "name": "Colombia" },
          "serviceType": [
            "Diseño de Interfaces Web (UI/UX)",
            "Desarrollo de Sitios Web Creativos",
            "Conceptualización de Imagen Corporativa"
          ],
          "telephone": "+573023725631",
          "email": "contacto@maurouix.com"
        }
      ]
    }
    </script>
    <ClientRouter />
    <!-- Microsoft Clarity -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "way9bkhjv4");
    </script>
  </head>
  <body>
    <!-- Skip to main content (accessibility) -->
    <a href="#main-content" class="skip-link">Saltar al contenido</a>

    <!-- Animated background grid -->
    <div class="grid-bg" id="grid-bg" aria-hidden="true"></div>

    <Header />

    <main id="main-content">
      <Hero />
      <div class="section-divider"></div>
      <Projects />
      <div class="section-divider"></div>
      <Services />
      <div class="section-divider"></div>
      <Philosophy />
      <div class="section-divider"></div>
      <Contact />
    </main>

    <!-- GSAP Scripts -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // ─── View Transition lifecycle (set up once per browser session) ───
      if (!(window as any).__transitionsInit) {
        (window as any).__transitionsInit = true;

        document.addEventListener('astro:before-preparation', (e: any) => {
          const from: string = e.from.pathname;
          const to: string = e.to.pathname;
          const backward = from.startsWith('/proyectos/') && !to.startsWith('/proyectos/');
          document.documentElement.dataset.direction = backward ? 'backward' : 'forward';
        });

        document.addEventListener('astro:before-swap', () => {
          ScrollTrigger.getAll().forEach((t) => t.kill());
        });
      }

      // ─────────────────────────────────────
      // 1. HERO — Letter-by-letter reveal
      // ─────────────────────────────────────
      function initHeroReveal() {
        const heroEl = document.getElementById('hero-text');
        if (!heroEl) return;

        const text = heroEl.textContent || '';
        heroEl.innerHTML = '';

        // Split into words, then chars
        const words = text.split(' ');
        words.forEach((word, wi) => {
          const wordSpan = document.createElement('span');
          wordSpan.className = 'word';

          for (let i = 0; i < word.length; i++) {
            const charSpan = document.createElement('span');
            charSpan.className = 'char';
            charSpan.textContent = word[i];
            wordSpan.appendChild(charSpan);
          }

          heroEl.appendChild(wordSpan);

          // Add space between words (not after the last one)
          if (wi < words.length - 1) {
            const space = document.createElement('span');
            space.className = 'word';
            space.innerHTML = '&nbsp;';
            heroEl.appendChild(space);
          }
        });

        // Animate each character
        const chars = heroEl.querySelectorAll('.char');
        gsap.fromTo(
          chars,
          {
            opacity: 0,
            y: 40,
            rotateX: -90,
          },
          {
            opacity: 1,
            y: 0,
            rotateX: 0,
            duration: 0.6,
            ease: 'power3.out',
            stagger: 0.025,
            delay: 0.3,
          }
        );
      }

      // ─────────────────────────────────────
      // 2. Scroll Reveal for sections
      // ─────────────────────────────────────
      function initScrollReveals() {
        const hash = window.location.hash;
        const hashTarget = hash ? document.querySelector(hash) : null;

        const revealEls = document.querySelectorAll('.reveal-up');
        revealEls.forEach((el) => {
          // If navigated with hash, instantly reveal elements inside the target section
          if (hashTarget && (hashTarget === el || hashTarget.contains(el))) {
            gsap.set(el, { opacity: 1, y: 0 });
            return;
          }
          gsap.fromTo(
            el,
            { opacity: 0, y: 30 },
            {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 88%',
                toggleActions: 'play none none none',
              },
            }
          );
        });
      }

      // ─────────────────────────────────────
      // 3. Background grid parallax
      // ─────────────────────────────────────
      function initGridParallax() {
        const gridBg = document.getElementById('grid-bg');
        if (!gridBg) return;

        gsap.to(gridBg, {
          backgroundPosition: '30px 200px',
          ease: 'none',
          scrollTrigger: {
            trigger: document.body,
            start: 'top top',
            end: 'bottom bottom',
            scrub: 1.5,
          },
        });
      }

      // ─────────────────────────────────────
      // 4. Project accordion
      // ─────────────────────────────────────
      function initAccordion() {
        const triggers = document.querySelectorAll('[data-accordion-trigger]');

        function closePanel(trigger: Element) {
          const item = trigger.closest('.project-item');
          if (!item) return;
          const panel = item.querySelector('[data-accordion-panel]') as HTMLElement;
          const icon = item.querySelector('.accordion-icon');
          if (!panel) return;
          gsap.to(panel, { height: 0, duration: 0.4, ease: 'power2.inOut' });
          if (icon) {
            icon.textContent = '+';
            gsap.to(icon, { rotation: 0, duration: 0.3 });
          }
          trigger.setAttribute('aria-expanded', 'false');
        }

        triggers.forEach((trigger) => {
          const handleOpen = () => {
            const item = trigger.closest('.project-item');
            if (!item) return;
            const panel = item.querySelector('[data-accordion-panel]') as HTMLElement;
            const icon = item.querySelector('.accordion-icon');
            if (!panel) return;

            const isOpen = trigger.getAttribute('aria-expanded') === 'true';

            // Close all other panels
            triggers.forEach((t) => {
              if (t !== trigger) closePanel(t);
            });

            if (isOpen) {
              closePanel(trigger);
            } else {
              // Open this panel
              gsap.set(panel, { height: 'auto' });
              const fullHeight = panel.offsetHeight;
              gsap.fromTo(
                panel,
                { height: 0 },
                { height: fullHeight, duration: 0.5, ease: 'power2.out' }
              );
              if (icon) {
                icon.textContent = '−';
                gsap.to(icon, { rotation: 180, duration: 0.3 });
              }
              trigger.setAttribute('aria-expanded', 'true');
            }
          };

          trigger.addEventListener('click', handleOpen);
          // Keyboard support (Enter/Space)
          trigger.addEventListener('keydown', (e: Event) => {
            const ke = e as KeyboardEvent;
            if (ke.key === 'Enter' || ke.key === ' ') {
              e.preventDefault();
              handleOpen();
            }
          });
        });
      }

      // ─────────────────────────────────────
      // 5. Header scroll styling
      // ─────────────────────────────────────
      function initHeaderScroll() {
        const header = document.getElementById('site-header');
        if (!header) return;

        ScrollTrigger.create({
          trigger: document.body,
          start: '100px top',
          onEnter: () => {
            header.style.backgroundColor = 'rgba(13,13,13,0.85)';
            header.style.backdropFilter = 'blur(12px)';
            header.style.webkitBackdropFilter = 'blur(12px)';
          },
          onLeaveBack: () => {
            header.style.backgroundColor = 'transparent';
            header.style.backdropFilter = 'none';
            header.style.webkitBackdropFilter = 'none';
          },
        });
      }

      // ─────────────────────────────────────
      // 6. Copy email
      // ─────────────────────────────────────
      function initCopyEmail() {
        const btn = document.getElementById('copy-email-btn');
        const label = document.getElementById('copy-label');
        if (!btn || !label) return;

        btn.addEventListener('click', async () => {
          const email = btn.getAttribute('data-email') || '';
          try {
            await navigator.clipboard.writeText(email);
            label.textContent = '¡Copiado!';
            btn.classList.add('copied');
            setTimeout(() => {
              label.textContent = 'Copiar';
              btn.classList.remove('copied');
            }, 2000);
          } catch {
            label.textContent = 'Error';
            setTimeout(() => { label.textContent = 'Copiar'; }, 2000);
          }
        });
      }

      // ─────────────────────────────────────
      // 7. Mobile menu
      // ─────────────────────────────────────
      function initMobileMenu() {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        if (!btn || !menu) return;

        let isOpen = false;

        function openMenu() {
          isOpen = true;
          menu.style.height = menu.scrollHeight + 'px';
          btn.setAttribute('aria-expanded', 'true');
          btn.setAttribute('aria-label', 'Cerrar menú de navegación');
          menu.setAttribute('aria-hidden', 'false');
        }

        function closeMenu() {
          isOpen = false;
          menu.style.height = '0';
          btn.setAttribute('aria-expanded', 'false');
          btn.setAttribute('aria-label', 'Abrir menú de navegación');
          menu.setAttribute('aria-hidden', 'true');
        }

        btn.addEventListener('click', () => {
          isOpen ? closeMenu() : openMenu();
        });

        // Close on link click
        menu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', closeMenu);
        });

        // Close on Escape
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && isOpen) closeMenu();
        });
      }

      // ─── Initialize everything ───
      document.addEventListener('astro:page-load', () => {
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (!reducedMotion) {
          initHeroReveal();
          initScrollReveals();
          initGridParallax();
        } else {
          // Immediately show all reveal elements without animation
          document.querySelectorAll('.reveal-up').forEach((el) => {
            gsap.set(el, { opacity: 1, y: 0 });
          });
        }

        initAccordion();
        initHeaderScroll();
        initCopyEmail();
        initMobileMenu();

        // Scroll to hash after everything is ready
        const hash = window.location.hash;
        if (hash) {
          const target = document.querySelector(hash) as HTMLElement;
          if (target) {
            // Reset to top instantly so the scroll feels intentional
            document.documentElement.style.scrollBehavior = 'auto';
            window.scrollTo(0, 0);
            // Wait for GSAP + ScrollTrigger to finish initializing, then scroll
            setTimeout(() => {
              ScrollTrigger.refresh();
              const top = target.getBoundingClientRect().top + window.scrollY;
              document.documentElement.style.scrollBehavior = '';
              window.scrollTo({ top, behavior: 'smooth' });
            }, 100);
          }
        }
      });
    </script>
  </body>
</html>
