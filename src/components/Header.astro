---

<header id="site-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 border-b border-[rgba(245,245,245,0.08)]">
  <div class="flex items-center justify-between pad-x pad-y-sm">
    <!-- Logo -->
    <div class="flex items-baseline gap-3">
      <a href="/" class="font-display text-lg md:text-xl font-black tracking-tight text-[var(--color-fg)] no-underline">
        MauroUIX
      </a>
      <span class="font-mono text-[0.65rem] tracking-[0.15em] uppercase text-[var(--color-muted)] hidden sm:inline">
        Diseñador Web &amp; Dev UI/UX
      </span>
    </div>

    <!-- Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="#work" class="nav-link">Work</a>
      <a href="#services" class="nav-link">Servicios</a>
      <a href="#about" class="nav-link">About</a>
      <a href="#contact" class="nav-link">Contact</a>
    </nav>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-[5px] p-2 bg-transparent border-none cursor-pointer" aria-label="Menu">
      <span class="block w-5 h-[1.5px] bg-[var(--color-fg)] transition-all duration-300"></span>
      <span class="block w-5 h-[1.5px] bg-[var(--color-fg)] transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="md:hidden overflow-hidden h-0 transition-all duration-500 pad-x">
    <nav class="flex flex-col gap-6 pb-8 pt-2">
      <a href="#work" class="nav-link text-base">Work</a>
      <a href="#services" class="nav-link text-base">Servicios</a>
      <a href="#about" class="nav-link text-base">About</a>
      <a href="#contact" class="nav-link text-base">Contact</a>
    </nav>
  </div>
</header>
