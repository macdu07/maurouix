---
---

<header id="site-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 border-b border-[var(--color-border)] bg-[rgba(244,239,230,0.82)] backdrop-blur-[14px]">
  <div class="flex items-center justify-between pad-x pad-y-sm">
    <!-- Logo -->
    <div class="flex items-center">
      <a href="/" class="inline-flex items-center text-[var(--color-accent)] no-underline" aria-label="Inicio Mauricio Correa">
        <img src="/brand/logotipo.png" alt="Mauricio Correa - UI/UX Web Designer & Web Developer" class="brand-logo-header" />
      </a>
    </div>

    <!-- Navigation -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Navegación principal">
      <a href="/#work" class="nav-link">Proyectos</a>
      <a href="/#services" class="nav-link">Servicios</a>
      <a href="/#about" class="nav-link">Sobre Mí</a>
      <a href="/#contact" class="nav-link">Contacto</a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-[5px] p-2 bg-transparent border-none cursor-pointer"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-5 h-[1.5px] bg-[var(--color-accent)] transition-all duration-300"></span>
      <span class="block w-5 h-[1.5px] bg-[var(--color-accent)] transition-all duration-300"></span>
      <span class="block w-5 h-[1.5px] bg-[var(--color-accent)] transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="md:hidden overflow-hidden h-0 transition-all duration-500 pad-x" aria-hidden="true">
    <nav class="flex flex-col gap-6 pb-8 pt-2" aria-label="Navegación móvil">
      <a href="/#work" class="nav-link text-base">Proyectos</a>
      <a href="/#services" class="nav-link text-base">Servicios</a>
      <a href="/#about" class="nav-link text-base">Sobre Mí</a>
      <a href="/#contact" class="nav-link text-base">Contacto</a>
    </nav>
  </div>
</header>
