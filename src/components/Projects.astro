---
import { visibleProjects } from '../data/projects';
---

<section id="work" class="section-pad relative z-10">
  <p class="section-label eyebrow-rule reveal-up">Portfolio</p>
  <h2 class="font-display font-semibold text-[clamp(3rem,6vw,6rem)] leading-[0.9] text-[var(--color-accent)] mb-16 reveal-up">
    Proyectos<br/>destacados
  </h2>

  <ul class="projects-list list-none">
    {visibleProjects.map((project, i) => (
      <li class="project-item reveal-up" data-index={i}>
        <div
          class="project-title-row py-8 md:py-10 cursor-pointer"
          data-accordion-trigger
          role="button"
          tabindex="0"
          aria-expanded="false"
          aria-label={`Ver detalles de ${project.title}`}
        >
          <div class="flex items-center gap-4 md:gap-8">
            <span class="font-mono text-[0.7rem] text-[var(--color-gold)] tracking-[0.18em] flex-shrink-0">
              {project.num}
            </span>
            <div class="flex-1">
              <h3 class="project-title font-display font-semibold text-[clamp(2rem,4vw,4rem)] leading-[0.95] text-[var(--color-fg)] transition-all duration-300">
                {project.title}
              </h3>
              <p class="font-mono text-[0.7rem] tracking-[0.1em] text-[var(--color-muted)] mt-3 uppercase">
                {project.meta}
              </p>
            </div>
            <span class="accordion-icon font-mono text-[var(--color-muted)] text-xl transition-transform duration-300 flex-shrink-0" aria-hidden="true">
              +
            </span>
          </div>
        </div>

        <div class="project-panel" data-accordion-panel>
          <div class="pb-10 pl-0 md:pl-[calc(0.7rem+2rem+8px)]">
            <p class="font-body text-base md:text-lg leading-relaxed text-[var(--color-fg)] max-w-[65ch] mb-6">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map((tag: string) => (
                <span class="tag-pill font-mono text-[0.65rem] tracking-[0.1em] uppercase px-3 py-1">
                  {tag}
                </span>
              ))}
            </div>
            <a href={`/proyectos/${project.slug}`} class="link-accent font-mono text-[0.75rem] tracking-[0.15em] uppercase">
              [ {project.cta} → ]
            </a>
          </div>
        </div>
      </li>
    ))}
  </ul>
</section>
