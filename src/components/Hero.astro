---
---

<section id="hero" class="min-h-screen flex items-center section-pad relative z-10 pt-32 overflow-hidden">
  <img
    src="/brand/monograma.png"
    alt=""
    class="brand-mark brand-mark-hero absolute right-[5vw] top-[18vh] -z-10 hidden md:block"
    aria-hidden="true"
  />
  <div class="w-full max-w-[72rem]">
    <p class="section-label eyebrow-rule reveal-up">Diseño Web & Desarrollo UI/UX</p>
    <h1
      id="hero-text"
      class="font-display font-semibold text-[clamp(2.9rem,9vw,9.5rem)] leading-[0.86] text-[var(--color-accent)]"
    >
      Transformando Ideas en Experiencias Digitales
    </h1>
    <div class="mt-12 reveal-up max-w-[58ch] border-l border-[var(--color-gold)] pl-6">
      <p class="font-body text-lg md:text-xl text-[var(--color-fg)]">
        +10 años creando soluciones visuales que conectan marcas con su audiencia.
      </p>
      <p class="font-mono text-[0.75rem] tracking-[0.12em] uppercase text-[var(--color-muted)] mt-8">
        Desliza para explorar <span class="scroll-hint ml-2" aria-hidden="true">↓</span>
      </p>
    </div>
  </div>
</section>
